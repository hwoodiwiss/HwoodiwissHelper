@page "/"

<PageTitle>Hwoodiwiss Helper</PageTitle>

<div class="home-hero mb-5">
    <h1 class="home-title">Hwoodiwiss Helper</h1>
    <p class="home-subtitle">A small collection of developer utilities. Pick a tool below to get started.</p>
</div>

<div class="row g-4">

    <div class="col-12 col-sm-6 col-xl-4">
        <a href="encoding" class="tool-card card h-100 text-decoration-none">
            <div class="card-body d-flex flex-column gap-3">
                <div class="tool-card-icon tool-card-icon--encoding" aria-hidden="true"></div>
                <div>
                    <h2 class="tool-card-title">Encoding</h2>
                    <p class="tool-card-desc">Convert text to and from Base64 and Base64-URL encoding. All three formats stay in sync as you type.</p>
                </div>
                <div class="mt-auto tool-card-cta">
                    Open <span aria-hidden="true">&rarr;</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-xl-4">
        <a href="cryptography" class="tool-card card h-100 text-decoration-none">
            <div class="card-body d-flex flex-column gap-3">
                <div class="tool-card-icon tool-card-icon--crypto" aria-hidden="true"></div>
                <div>
                    <h2 class="tool-card-title">Cryptography</h2>
                    <p class="tool-card-desc">Generate cryptographically secure random strings of any size. Useful for secrets, tokens, and keys.</p>
                </div>
                <div class="mt-auto tool-card-cta">
                    Open <span aria-hidden="true">&rarr;</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 col-sm-6 col-xl-4">
        <a href="games/phase10" class="tool-card card h-100 text-decoration-none">
            <div class="card-body d-flex flex-column gap-3">
                <div class="tool-card-icon tool-card-icon--phase10" aria-hidden="true"></div>
                <div>
                    <h2 class="tool-card-title">Phase 10 Scorer</h2>
                    <p class="tool-card-desc">Track scores and phase progress across rounds for up to 6 players. Game state is saved automatically.</p>
                </div>
                <div class="mt-auto tool-card-cta">
                    Open <span aria-hidden="true">&rarr;</span>
                </div>
            </div>
        </a>
    </div>

</div>
