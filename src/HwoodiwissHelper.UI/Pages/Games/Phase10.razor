@page "/games/phase10"
@using System.Text.Json
@inject IJSRuntime JsRuntime

<PageTitle>Phase 10 Scorer</PageTitle>

<h1>Phase 10 Scorer</h1>

@if (_game is null)
{
    <p>Track scores and phase progress across rounds. Scores represent penalty points — lower is better.</p>

    <h2>New Game</h2>
    <p class="text-muted">Enter player names (2–6 players).</p>

    @for (int i = 0; i < _setupPlayerNames.Count; i++)
    {
        var index = i;
        <div @key="index" class="mb-2 d-flex gap-2 align-items-center" style="max-width: 400px;">
            <input class="form-control" type="text" placeholder="@($"Player {index + 1}")"
                   @bind="_setupPlayerNames[index]" />
            <button class="btn btn-outline-danger btn-sm"
                    disabled="@(_setupPlayerNames.Count <= 2)"
                    @onclick="() => RemovePlayer(index)">
                Remove
            </button>
        </div>
    }

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-outline-secondary"
                disabled="@(_setupPlayerNames.Count >= 6)"
                @onclick="AddPlayer">
            + Add Player
        </button>
        <button class="btn btn-primary"
                disabled="@(!CanStartGame())"
                @onclick="StartGame">
            Start Game
        </button>
    </div>
}
else if (_game.IsComplete)
{
    <div class="alert alert-success">
        <strong>@GameWinner!.Name wins!</strong>
        @if (CompletedPlayerCount > 1)
        {
            <span> (@CompletedPlayerCount players completed Phase 10 this round — winner has lowest score.)</span>
        }
        else
        {
            <span> Completed Phase 10 with @GameWinner.TotalScore penalty points.</span>
        }
    </div>

    <h2>Final Standings</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Place</th>
                <th>Player</th>
                <th>Final Phase</th>
                <th>Total Score</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (place, player) in GameOverStandings.Select((p, i) => (i + 1, p)))
            {
                <tr class="@(player.CompletedGame ? "table-success" : "")">
                    <td>@place</td>
                    <td>@player.Name</td>
                    <td>@(player.CompletedGame ? "Completed" : $"Phase {player.CurrentPhase}")</td>
                    <td>@player.TotalScore</td>
                </tr>
            }
        </tbody>
    </table>

    <h2>Round History</h2>
    <div class="table-responsive">
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Round</th>
                    @foreach (var p in _game.Players)
                    {
                        <th>@p.Name</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var round in _game.Rounds)
                {
                    <tr>
                        <td>@round.RoundNumber</td>
                        @foreach (var entry in round.Entries)
                        {
                            <td class="@(entry.PhaseCompleted ? "table-success" : "")">
                                <span>Phase @entry.Phase</span>
                                <br />
                                <small>@(entry.PhaseCompleted ? "Progressed" : "Stayed") &mdash; @entry.PointsAdded pts</small>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="NewGame">New Game</button>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Round @_game.CurrentRound</h2>
        <button class="btn btn-outline-danger btn-sm" @onclick="AbandonGame">Abandon Game</button>
    </div>

    <h3>Standings</h3>
    <table class="table table-sm table-bordered mb-4">
        <thead>
            <tr>
                <th>Player</th>
                <th>Current Phase</th>
                <th>Total Score</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in ActiveStandings)
            {
                <tr>
                    <td>@player.Name</td>
                    <td>Phase @player.CurrentPhase</td>
                    <td>@player.TotalScore</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Round @_game.CurrentRound Scores</h3>
    <p class="text-muted">Enter each player's penalty points (cards left in hand) and whether they completed their phase.</p>

    <div class="row gy-3 mb-4">
        @for (int i = 0; i < _game.Players.Count; i++)
        {
            var index = i;
            var player = _game.Players[index];
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@player.Name</h5>
                        <p class="card-subtitle text-muted mb-3">Phase @player.CurrentPhase</p>
                        <div class="mb-3">
                            <label class="form-label" for="points-@index">Penalty Points</label>
                            <input class="form-control" id="points-@index" type="number"
                                   min="0" step="5" placeholder="0"
                                   @bind="_roundEntries[index].Points" />
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="phase-done-@index"
                                   @bind="_roundEntries[index].PhaseCompleted" />
                            <label class="form-check-label" for="phase-done-@index">
                                Completed Phase @player.CurrentPhase
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (_game.Rounds.Count > 0)
    {
        <details class="mb-4">
            <summary class="text-muted" style="cursor: pointer;">Round History</summary>
            <div class="table-responsive mt-2">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Round</th>
                            @foreach (var p in _game.Players)
                            {
                                <th>@p.Name</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var round in _game.Rounds)
                        {
                            <tr>
                                <td>@round.RoundNumber</td>
                                @foreach (var entry in round.Entries)
                                {
                                    <td class="@(entry.PhaseCompleted ? "table-success" : "")">
                                        <span>Phase @entry.Phase</span>
                                        <br />
                                        <small>@(entry.PhaseCompleted ? "Progressed" : "Stayed") &mdash; @entry.PointsAdded pts</small>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }

    <button class="btn btn-primary" @onclick="SubmitRound">Submit Round</button>
}

@code {
    private const string StorageKey = "phase10-game";

    private Phase10Game? _game;
    private List<string> _setupPlayerNames = ["", ""];
    private RoundEntryModel[] _roundEntries = [];

    // ── Computed properties used in markup ────────────────────────────────────

    private Phase10Player? GameWinner =>
        _game?.Players.Where(p => p.CompletedGame).OrderBy(p => p.TotalScore).FirstOrDefault();

    private int CompletedPlayerCount =>
        _game?.Players.Count(p => p.CompletedGame) ?? 0;

    private IEnumerable<Phase10Player> GameOverStandings =>
        _game?.Players
            .OrderByDescending(p => p.CompletedGame ? 1 : 0)
            .ThenByDescending(p => p.CurrentPhase)
            .ThenBy(p => p.TotalScore)
        ?? Enumerable.Empty<Phase10Player>();

    private IEnumerable<Phase10Player> ActiveStandings =>
        _game?.Players
            .OrderByDescending(p => p.CurrentPhase)
            .ThenBy(p => p.TotalScore)
        ?? Enumerable.Empty<Phase10Player>();

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var json = await JsRuntime.InvokeAsync<string?>("localStorage.getItem", StorageKey);
        if (json is not null)
        {
            try
            {
                _game = JsonSerializer.Deserialize<Phase10Game>(json);
                if (_game is not null)
                    InitRoundEntries();
            }
            catch
            {
                // Corrupted storage — clear it and let the user start fresh
                await JsRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
            }
        }
    }

    private void InitRoundEntries()
    {
        if (_game is null) return;
        _roundEntries = _game.Players.Select(_ => new RoundEntryModel()).ToArray();
    }

    // ── Setup actions ─────────────────────────────────────────────────────────

    private bool CanStartGame() =>
        _setupPlayerNames.Count >= 2 &&
        _setupPlayerNames.All(n => !string.IsNullOrWhiteSpace(n));

    private void AddPlayer()
    {
        if (_setupPlayerNames.Count < 6)
            _setupPlayerNames.Add("");
    }

    private void RemovePlayer(int index)
    {
        if (_setupPlayerNames.Count > 2)
            _setupPlayerNames.RemoveAt(index);
    }

    private async Task StartGame()
    {
        if (!CanStartGame()) return;

        _game = new Phase10Game
        {
            Players = _setupPlayerNames
                .Select(n => new Phase10Player { Name = n.Trim() })
                .ToList()
        };

        InitRoundEntries();
        await SaveGame();
    }

    // ── Game actions ──────────────────────────────────────────────────────────

    private async Task SubmitRound()
    {
        if (_game is null) return;

        var round = new Phase10Round { RoundNumber = _game.CurrentRound };

        for (int i = 0; i < _game.Players.Count; i++)
        {
            var player = _game.Players[i];
            var entry = _roundEntries[i];

            round.Entries.Add(new Phase10RoundEntry
            {
                PlayerName = player.Name,
                Phase = player.CurrentPhase,
                PhaseCompleted = entry.PhaseCompleted,
                PointsAdded = entry.Points
            });

            player.TotalScore += entry.Points;

            if (entry.PhaseCompleted)
            {
                if (player.CurrentPhase >= 10)
                    player.CompletedGame = true;
                else
                    player.CurrentPhase++;
            }
        }

        _game.Rounds.Add(round);
        _game.CurrentRound++;

        if (_game.Players.Any(p => p.CompletedGame))
            _game.IsComplete = true;

        // Reset round entry fields for the next round
        foreach (var entry in _roundEntries)
        {
            entry.Points = 0;
            entry.PhaseCompleted = false;
        }

        await SaveGame();
    }

    private async Task AbandonGame()
    {
        _game = null;
        _roundEntries = [];
        _setupPlayerNames = ["", ""];
        await JsRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
    }

    private async Task NewGame()
    {
        _game = null;
        _roundEntries = [];
        _setupPlayerNames = ["", ""];
        await JsRuntime.InvokeVoidAsync("localStorage.removeItem", StorageKey);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private async Task SaveGame()
    {
        var json = JsonSerializer.Serialize(_game);
        await JsRuntime.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
    }

    // ── Models ────────────────────────────────────────────────────────────────

    private sealed class Phase10Game
    {
        public List<Phase10Player> Players { get; set; } = [];
        public List<Phase10Round> Rounds { get; set; } = [];
        public int CurrentRound { get; set; } = 1;
        public bool IsComplete { get; set; }
    }

    private sealed class Phase10Player
    {
        public string Name { get; set; } = "";
        public int CurrentPhase { get; set; } = 1;
        public int TotalScore { get; set; }
        public bool CompletedGame { get; set; }
    }

    private sealed class Phase10Round
    {
        public int RoundNumber { get; set; }
        public List<Phase10RoundEntry> Entries { get; set; } = [];
    }

    private sealed class Phase10RoundEntry
    {
        public string PlayerName { get; set; } = "";
        public int Phase { get; set; }
        public bool PhaseCompleted { get; set; }
        public int PointsAdded { get; set; }
    }

    private sealed class RoundEntryModel
    {
        public int Points { get; set; }
        public bool PhaseCompleted { get; set; }
    }
}
