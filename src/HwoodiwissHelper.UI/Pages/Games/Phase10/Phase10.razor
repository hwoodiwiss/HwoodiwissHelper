@page "/games/phase10"
@using HwoodiwissHelper.UI.Pages.Games.Phase10
@inject IPhase10GameService GameService

<PageTitle>Phase 10 Scorer</PageTitle>

<h1>Phase 10 Scorer</h1>

@if (GameService.State is Phase10GameState.Setup setup)
{
    <p>Track scores and phase progress across rounds. Scores represent penalty points — lower is better.</p>

    <h2>New Game</h2>
    <p class="text-muted">Enter player names (2–6 players).</p>

    @for (int i = 0; i < setup.PlayerNames.Count; i++)
    {
        var index = i;
        <div @key="index" class="mb-2 d-flex gap-2 align-items-center" style="max-width: 400px;">
            <input class="form-control" type="text" placeholder="@($"Player {index + 1}")"
                   @bind="setup.PlayerNames[index]" />
            <button class="btn btn-outline-danger btn-sm"
                    disabled="@(setup.PlayerNames.Count <= 2)"
                    @onclick="() => GameService.RemovePlayer(index)">
                Remove
            </button>
        </div>
    }

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-outline-secondary"
                disabled="@(setup.PlayerNames.Count >= 6)"
                @onclick="GameService.AddPlayer">
            + Add Player
        </button>
        <button class="btn btn-primary"
                disabled="@(!setup.CanStart)"
                @onclick="GameService.StartGameAsync">
            Start Game
        </button>
    </div>
}
else if (GameService.State is Phase10GameState.Complete complete)
{
    <div class="alert alert-success">
        <strong>@complete.Winner.PlayerName wins!</strong>
        @if (complete.CompletedPlayerCount > 1)
        {
            <span> (@complete.CompletedPlayerCount players completed Phase 10 this round — winner has lowest score.)</span>
        }
        else
        {
            <span> Completed Phase 10 with @complete.Winner.Score penalty points.</span>
        }
    </div>

    <h2>Final Standings</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Place</th>
                <th>Player</th>
                <th>Final Phase</th>
                <th>Total Score</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (place, player) in complete.GameOverStandings.Select((p, i) => (i + 1, p)))
            {
                <tr class="@(player is Phase10Player.Completed ? "table-success" : "")">
                    <td>@place</td>
                    <td>@(player switch { Phase10Player.Active a => a.PlayerName, Phase10Player.Completed c => c.PlayerName, _ => "" })</td>
                    <td>@(player switch { Phase10Player.Completed => "Completed", Phase10Player.Active a => $"Phase {a.Phase}", _ => "" })</td>
                    <td>@(player switch { Phase10Player.Active a => a.Score, Phase10Player.Completed c => c.Score, _ => 0 })</td>
                </tr>
            }
        </tbody>
    </table>

    <h2>Round History</h2>
    <div class="table-responsive">
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Round</th>
                    @foreach (var p in complete.Game.Players)
                    {
                        <th>@(p switch { Phase10Player.Active a => a.PlayerName, Phase10Player.Completed c => c.PlayerName, _ => "" })</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var round in complete.Game.Rounds)
                {
                    <tr>
                        <td>@round.RoundNumber</td>
                        @foreach (var entry in round.Entries)
                        {
                            <td class="@(entry.PhaseCompleted ? "table-success" : "")">
                                <span>Phase @entry.Phase</span>
                                <br />
                                <small>@(entry.PhaseCompleted ? "Progressed" : "Stayed") &mdash; @entry.PointsAdded pts</small>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="GameService.NewGameAsync">New Game</button>
    </div>
}
else if (GameService.State is Phase10GameState.InProgress active)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Round @active.Game.CurrentRound</h2>
        <button class="btn btn-outline-danger btn-sm" @onclick="GameService.AbandonGameAsync">Abandon Game</button>
    </div>

    <h3>Standings</h3>
    <table class="table table-sm table-bordered mb-4">
        <thead>
            <tr>
                <th>Player</th>
                <th>Current Phase</th>
                <th>Total Score</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in active.ActiveStandings)
            {
                <tr>
                    <td>@(player switch { Phase10Player.Active a => a.PlayerName, Phase10Player.Completed c => c.PlayerName, _ => "" })</td>
                    <td>@(player switch { Phase10Player.Active a => $"Phase {a.Phase}", Phase10Player.Completed => "Completed", _ => "" })</td>
                    <td>@(player switch { Phase10Player.Active a => a.Score, Phase10Player.Completed c => c.Score, _ => 0 })</td>
                </tr>
            }
        </tbody>
    </table>

    <h3>Round @active.Game.CurrentRound Scores</h3>
    <p class="text-muted">Enter each player's penalty points (cards left in hand) and whether they completed their phase.</p>

    <div class="row gy-3 mb-4">
        @for (int i = 0; i < active.Game.Players.Count; i++)
        {
            var index = i;
            var player = active.Game.Players[index];
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@(player switch { Phase10Player.Active a => a.PlayerName, Phase10Player.Completed c => c.PlayerName, _ => "" })</h5>
                        <p class="card-subtitle text-muted mb-3">@(player switch { Phase10Player.Active a => $"Phase {a.Phase}", Phase10Player.Completed => "Completed", _ => "" })</p>
                        <div class="mb-3">
                            <label class="form-label" for="points-@index">Penalty Points</label>
                            <input class="form-control" id="points-@index" type="number"
                                   min="0" step="5" placeholder="0"
                                   @bind="active.Entries[index].Points" />
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="phase-done-@index"
                                   @bind="active.Entries[index].PhaseCompleted" />
                            <label class="form-check-label" for="phase-done-@index">
                                Completed @(player switch { Phase10Player.Active a => $"Phase {a.Phase}", Phase10Player.Completed => "the game", _ => "" })
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (active.Game.Rounds.Count > 0)
    {
        <details class="mb-4">
            <summary class="text-muted" style="cursor: pointer;">Round History</summary>
            <div class="table-responsive mt-2">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Round</th>
                            @foreach (var p in active.Game.Players)
                            {
                                <th>@(p switch { Phase10Player.Active a => a.PlayerName, Phase10Player.Completed c => c.PlayerName, _ => "" })</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var round in active.Game.Rounds)
                        {
                            <tr>
                                <td>@round.RoundNumber</td>
                                @foreach (var entry in round.Entries)
                                {
                                    <td class="@(entry.PhaseCompleted ? "table-success" : "")">
                                        <span>Phase @entry.Phase</span>
                                        <br />
                                        <small>@(entry.PhaseCompleted ? "Progressed" : "Stayed") &mdash; @entry.PointsAdded pts</small>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }

    <button class="btn btn-primary" @onclick="GameService.SubmitRoundAsync">Submit Round</button>
}

@code {
    protected override async Task OnInitializedAsync()
        => await GameService.LoadGameAsync();
}
